<?xml version="1.0"?>
<psalm
    errorLevel="1"
    resolveFromConfigFile="true"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://getpsalm.org/schema/config"
    xsi:schemaLocation="https://getpsalm.org/schema/config vendor/vimeo/psalm/config.xsd"
    findUnusedBaselineEntry="true"
    findUnusedCode="true"
	phpVersion="8.1"
>
    <projectFiles>
        <directory name="lib" />
        <ignoreFiles>
            <directory name="vendor" />
        </ignoreFiles>
    </projectFiles>
	<extraFiles>
		<directory name="vendor"/>
	</extraFiles>
	<issueHandlers>
		<!-- Migrations are loaded by Nextcloud's migration runner, never directly -->
		<UnusedClass>
			<errorLevel type="suppress">
				<directory name="lib/Migration"/>
			</errorLevel>
		</UnusedClass>
		<!-- Nextcloud's OCP stubs reference Doctrine\DBAL\Schema\Table, which isn't installed -->
		<UndefinedDocblockClass>
			<errorLevel type="suppress">
				<directory name="lib/Migration"/>
			</errorLevel>
		</UndefinedDocblockClass>
		<UnnecessaryVarAnnotation>
			<errorLevel type="suppress">
				<directory name="lib/Migration"/>
			</errorLevel>
		</UnnecessaryVarAnnotation>
		<!-- Service constructors and methods, plus Mapper constructors, are called via Nextcloud's DI container -->
		<PossiblyUnusedMethod>
			<errorLevel type="suppress">
				<directory name="lib/Service"/>
				<directory name="lib/Db"/>
			</errorLevel>
		</PossiblyUnusedMethod>
		<!-- Db Entities use property hydration via the Entity base class, not the constructor -->
		<PropertyNotSetInConstructor>
			<errorLevel type="suppress">
				<directory name="lib/Db"/>
			</errorLevel>
		</PropertyNotSetInConstructor>
		<!-- Entity properties are accessed via magic getters/setters generated by Nextcloud's Entity base -->
		<PossiblyUnusedProperty>
			<errorLevel type="suppress">
				<directory name="lib/Db"/>
			</errorLevel>
		</PossiblyUnusedProperty>
	</issueHandlers>
</psalm>
